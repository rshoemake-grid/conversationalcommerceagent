server:
  port: 8080

# CORS - use specific origins in production (e.g. https://your-frontend.com)
app:
  cors:
    allowed-origins: "*"
  gcp:
    # GCP credentials path. Override with GOOGLE_APPLICATION_CREDENTIALS env var.
    credentials-path: ${GOOGLE_APPLICATION_CREDENTIALS:C:/Users/rsho0016/AppData/Roaming/gcloud/application_default_credentials.json}

# REST API docs (default: /v3/api-docs, /swagger-ui/index.html)
springdoc:
  api-docs:
    path: /v3/api-docs

spring:
  application:
    name: conversational-commerce-agent

# GCP Conversational Commerce - always enabled
# transport: "rest" (default) or "grpc" - rest bypasses ALPN/VPN issues
# Set project-id (or GCP_PROJECT_ID); placement and branch derive from it when not overridden.
# Copy this file to application.yml and adjust. application.yml is gitignored.
conversational-commerce:
  transport: ${CONVERSATIONAL_COMMERCE_TRANSPORT:rest}
  project-id: ${GCP_PROJECT_ID:your-project-id}
  placement: ${GCP_PLACEMENT:projects/${conversational-commerce.project-id}/locations/global/catalogs/default_catalog/placements/default_search}
  branch: ${GCP_BRANCH:projects/${conversational-commerce.project-id}/locations/global/catalogs/default_catalog/branches/default_branch}
  default-visitor-id: default-visitor
  # ENABLED lets the agent ask follow-up questions. Requires GCP Console setup (see CONFIG.md).
  conversational-filtering-mode: ${CONVERSATIONAL_FILTERING_MODE:DISABLED}
  # GCP returns attributes.stockType; use "stockType" for product filters
  stock-type-filter-attribute: ${STOCK_TYPE_FILTER_ATTRIBUTE:stockType}
  # Max products returned per search (REST and gRPC)
  product-search-page-size: ${PRODUCT_SEARCH_PAGE_SIZE:20}
  # Above this count we ask to narrow
  product-count-threshold: ${PRODUCT_COUNT_THRESHOLD:50}
  # Attribute mappings - see .cursor/rules/attribute-mappings.mdc
  #
  # Conversational filtering returns productAttributeValue.name like "attributes.<key>"; BrandDisplayResolver
  # strips the "attributes." prefix and looks up the key below. Keys come from your catalog and
  # raw API responses. Use scripts/collect_conversational_filtering_attributes.py to discover values.
  #
  # Display: API value -> label for UI. Expansion: user/short input -> canonical value for GCP.
  attribute-display-mapping:
    storageType:  # Stock / storage (D/R/S and F/C codes)
      F: Frozen
      C: Refrigerated
      S: Ambient
      R: Refrigerated
      D: Dry storage
      FROZEN: Frozen
      REFRIGERATED: Refrigerated
      AMBIENT: Ambient
      DRY_STORAGE: Dry storage
      COOLER: Refrigerated
      FREEZER: Frozen
      ROOM_TEMP: Ambient
    stockType:  # Same codes as storageType when filters use attributes.stockType
      F: Frozen
      C: Refrigerated
      S: Ambient
      R: Refrigerated
      D: Dry storage
      FROZEN: Frozen
      REFRIGERATED: Refrigerated
      AMBIENT: Ambient
      DRY_STORAGE: Dry storage
    departments:  # Department taxonomy (replace with your catalog)
      syy_cust_tax_meatseafood: Meat & Seafood
      syy_cust_tax_frozenfoods: Frozen Foods
      syy_cust_tax_canneddry: Canned & Dry
      syy_cust_tax_produce: Produce
      syy_cust_tax_bakerybread: Bakery & Bread
      syy_cust_tax_disposables: Disposables
      syy_cust_tax_equipmentsupplies: Equipment & Supplies
      syy_cust_tax_dairy: Dairy
      syy_cust_tax_deli: Deli
      syy_cust_tax_beverages: Beverages
      syy_cust_tax_snacks: Snacks
      syy_cust_tax_condiments: Condiments & Sauces
      syy_cust_tax_paper: Paper & Cleaning
    dietary:  # Diet / certification claims (adjust canonical keys to match catalog)
      ORGANIC: Organic
      NON_GMO: Non-GMO
      GLUTEN_FREE: Gluten free
      GF: Gluten free
      VEGAN: Vegan
      KOSHER: Kosher
      HALAL: Halal
      PLANT_BASED: Plant based
    allergens:  # Allergen / free-from flags
      CONTAINS_MILK: Contains milk
      CONTAINS_NUTS: Contains nuts
      CONTAINS_SOY: Contains soy
      CONTAINS_WHEAT: Contains wheat
      CONTAINS_EGG: Contains egg
      DAIRY_FREE: Dairy free
      NUT_FREE: Nut free
    unitOfMeasure:  # Sell unit / pack
      EA: Each
      CS: Case
      LB: Pound
      OZ: Ounce
      GAL: Gallon
      CT: Count
      PK: Pack
      BG: Bag
      BX: Box
    apparelSize:  # Apparel sizing if used
      XS: XS
      S: S
      M: M
      L: L
      XL: XL
      XXL: XXL
    color:  # Custom color attribute (attributes.color)
      BLK: Black
      WHT: White
      RED: Red
      BLU: Blue
      GRN: Green
      NAVY: Navy
      GRAY: Gray
    colorFamilies:  # Rollup key colorFamilies (Retail search)
      Black: Black
      White: White
      Red: Red
      Blue: Blue
      Green: Green
      Multicolor: Multicolor
    type:  # Product / decoration / subtype
      Balloons: Balloons
      Streamers: Streamers
      Tablecloths: Tablecloths
    sizes:  # Pack / unit size when API sends attributes.sizes or unnamed size values
      "12oz": 12 oz
      "24oz": 24 oz
      "16oz": 16 oz
      "32oz": 32 oz
      "1gal": 1 gal
      "1L": 1 L
    packageSize:  # Alternate key some catalogs use
      "12oz": 12 oz
      "24oz": 24 oz
    materials:  # attributes.materials
      PLASTIC: Plastic
      PAPER: Paper
      METAL: Metal
      GLASS: Glass
      WOOD: Wood
      FABRIC: Fabric
