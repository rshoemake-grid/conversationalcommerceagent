server:
  port: 8080

# CORS - use specific origins in production (e.g. https://your-frontend.com)
app:
  cors:
    allowed-origins: "*"

# REST API docs
springdoc:
  api-docs:
    path: /v3/api-docs
  swagger-ui:
    path: /swagger-ui.html

spring:
  application:
    name: conversational-commerce-agent

# GCP Conversational Commerce - copy this file to application.yml and configure.
# Set enabled=true when you have GCP credentials and Retail catalog configured.
conversational-commerce:
  enabled: ${CONVERSATIONAL_COMMERCE_ENABLED:false}
  project-id: ${GCP_PROJECT_ID:your-project-id}
  placement: ${GCP_PLACEMENT:projects/your-project-id/locations/global/catalogs/default_catalog/placements/default_search}
  branch: ${GCP_BRANCH:projects/your-project-id/locations/global/catalogs/default_catalog/branches/default_branch}
  default-visitor-id: default-visitor
